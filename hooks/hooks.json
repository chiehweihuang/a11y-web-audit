{
  "description": "Auto-triggers a11y advisor when UI files are edited",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/a11y-advisor-hook.mjs"
          }
        ]
      }
    ]
  }
}
